{
  "$description": "Cobru motion tokens",
  "motion": {
    "preset": {
      "fade-up": {
        "$type": "object",
        "$value": {
          "initial": { "opacity": 0, "y": 24 },
          "animate": { "opacity": 1, "y": 0 }
        }
      },
      "fade-in": {
        "$type": "object",
        "$value": {
          "initial": { "opacity": 0 },
          "animate": { "opacity": 1 }
        }
      },
      "scale-in": {
        "$type": "object",
        "$value": {
          "initial": { "opacity": 0, "scale": 0.95 },
          "animate": { "opacity": 1, "scale": 1 }
        }
      },
      "slide-in-right": {
        "$type": "object",
        "$value": {
          "initial": { "opacity": 0, "x": 32 },
          "animate": { "opacity": 1, "x": 0 }
        }
      }
    },
    "variant": {
      "container": {
        "$type": "object",
        "$value": {
          "hidden": { "opacity": 0 },
          "show": { "opacity": 1, "transition": { "staggerChildren": 0.1, "delayChildren": 0.1 } }
        }
      },
      "item": {
        "$type": "object",
        "$value": {
          "hidden": { "opacity": 0, "y": 20 },
          "show": { "opacity": 1, "y": 0 }
        }
      },
      "item-fast": {
        "$type": "object",
        "$value": {
          "hidden": { "opacity": 0, "y": 12 },
          "show": { "opacity": 1, "y": 0 }
        }
      }
    }
  }
}
