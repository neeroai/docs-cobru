{
  "name": "docs-cobru",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.9",
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check app components i18n lib next.config.mjs postcss.config.mjs proxy.ts source.config.ts package.json tsconfig.json biome.json vercel.json",
    "openapi:bundle": "redocly bundle openapi/src/openapi.yaml --output openapi/cobru.yaml",
    "openapi:check:bundle": "node scripts/check-openapi-bundle-sync.mjs",
    "openapi:lint": "redocly lint openapi/src/openapi.yaml",
    "openapi:validate": "node scripts/validate-openapi.mjs",
    "openapi:check:locales": "node scripts/validate-openapi-locales.mjs",
    "openapi:validate:strict": "node scripts/validate-openapi.mjs --require-non-placeholder",
    "content:check:sync": "node scripts/validate-content-sync.mjs",
    "smoke:api-reference": "node scripts/smoke-api-reference.mjs",
    "ci:governance": "bun run openapi:check:bundle && bun run openapi:lint && bun run openapi:validate && bun run openapi:check:locales && bun run content:check:sync",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@types/mdx": "^2.0.13",
    "fumadocs-core": "^16.7.0",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-openapi": "^10.6.6",
    "fumadocs-ui": "^16.7.10",
    "next": "^16.0.0",
    "next-intl": "^4.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shiki": "^3.0.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@redocly/cli": "^2.25.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.8.0",
    "yaml": "^2.8.3"
  }
}
